# Frontend environment variables for Vite
# Copy to .env.local and set to your backend URL.
# Use HTTPS when the site is opened via an https domain (e.g., Dev Tunnels),
# otherwise the browser will block mixed-content requests.

# Local development (backend on port 8000)
# VITE_API_BASE_URL=http://localhost:8000

# Azure Dev Tunnels (backend tunnel URL)
# Example: VITE_API_BASE_URL=https://YOUR-TUNNEL.euw.devtunnels.ms
